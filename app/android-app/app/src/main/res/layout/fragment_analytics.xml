<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <!-- Header with Menu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="@string/cd_menu_icon"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/margin_medium"
                android:text="@string/my_analytics"
                android:textColor="@color/textPrimary"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="end"/>

        </LinearLayout>

        <!-- Monthly Spending Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/monthly_spending"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <!-- Spending Amount -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/currency_ksh"
                android:textColor="@color/accentGreen"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_monthly_spending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="14,200"
                android:textColor="@color/textPrimary"
                android:textSize="32sp"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <!-- Spending Breakdown Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/spending_breakdown"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <!-- Pie Chart with Legend -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Pie Chart -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pie_chart"
                android:layout_width="180dp"
                android:layout_height="180dp"/>

            <!-- Legend -->
            <LinearLayout
                android:id="@+id/legend_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/margin_medium"
                android:orientation="vertical">

                <!-- Legend items will be added dynamically -->
                <include layout="@layout/item_legend"
                    android:id="@+id/legend_1"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Top Merchants & Frequent Payments -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Top Merchants -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/top_merchants"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:id="@+id/top_merchants_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:orientation="vertical">

                    <!-- Merchant items will be added dynamically -->

                </LinearLayout>

            </LinearLayout>

            <!-- Frequent Payments -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/margin_medium">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/frequent_payments"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:id="@+id/frequent_payments_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:orientation="vertical">

                    <!-- Payment items will be added dynamically -->

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

